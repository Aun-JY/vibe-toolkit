---
// src/layouts/BaseLayout.astro
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  type?: 'website' | 'article';
  publishDate?: string;
  keywords?: string[];
}

const { title, description, ogImage, type, publishDate, keywords } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <SEO
    title={title}
    description={description}
    ogImage={ogImage}
    type={type}
    publishDate={publishDate}
    keywords={keywords}
  />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
