---
// src/pages/ko/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';

const tools = [
  {
    title: '파비콘 (Favicon)',
    description: '브라우저 탭에 표시되는 작은 아이콘. SVG, PNG, ICO 형식별 코드와 동작 원리를 알아보세요.',
    href: '/ko/tools/favicon/',
    icon: '🌐',
    tags: ['HTML', 'SVG', 'SEO'],
    isNew: true,
  },
  {
    title: '플로팅 버튼',
    description: '화면 하단에 고정되는 플로팅 액션 버튼. 순수 CSS와 JS로 구현하는 방법을 소개합니다.',
    href: '/ko/tools/floating-button/',
    icon: '🔘',
    tags: ['CSS', 'JS'],
    isComingSoon: true,
  },
  {
    title: '로딩 스피너',
    description: '데이터 로딩 중 보여주는 애니메이션. CSS only로 만드는 10가지 스피너 모음.',
    href: '/ko/tools/loading-spinner/',
    icon: '⏳',
    tags: ['CSS', 'Animation'],
    isComingSoon: true,
  },
  {
    title: '토스트 알림',
    description: '화면 모서리에 잠깐 보이는 알림 메시지 컴포넌트. 복사하면 바로 동작합니다.',
    href: '/ko/tools/toast-notification/',
    icon: '🔔',
    tags: ['HTML', 'CSS', 'JS'],
    isComingSoon: true,
  },
  {
    title: '다크모드 토글',
    description: '클릭 한 번으로 라이트/다크 모드 전환. localStorage로 설정을 저장하는 방법까지.',
    href: '/ko/tools/dark-mode-toggle/',
    icon: '🌙',
    tags: ['CSS', 'JS'],
    isComingSoon: true,
  },
  {
    title: '스크롤 진행률 바',
    description: '페이지 상단에 읽은 위치를 표시하는 얇은 진행률 바. 블로그에 딱입니다.',
    href: '/ko/tools/scroll-progress/',
    icon: '📊',
    tags: ['CSS', 'JS'],
    isComingSoon: true,
  },
];
---

<BaseLayout
  title="바이브툴킷"
  description="바이브 코딩을 하는 초보 개발자를 위한 실용 웹 도구 모음. 파비콘, 플로팅 버튼, 토스트 알림 등 바로 복사해서 쓸 수 있는 코드 스니펫과 설명을 제공합니다."
  keywords={['웹개발 도구', '코드 스니펫', '바이브코딩', '프론트엔드']}
>

  <!-- 히어로 섹션 -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">
        <span class="tag">🎯 바이브 코더를 위한</span>
      </div>
      <h1>복붙하면 바로 되는<br /><span class="accent">웹 도구 모음</span></h1>
      <p class="hero-desc">
        파비콘이 뭔지, 왜 쓰는지, 어떻게 쓰는지.
        코드는 바로 복사해서 쓸 수 있게.
        그게 전부예요.
      </p>
      <div class="hero-actions">
        <a href="/ko/tools/favicon/" class="btn btn-primary">첫 번째 도구 보기 →</a>
        <a href="#tools" class="btn btn-ghost">전체 목록 ↓</a>
      </div>

      <!-- 통계 -->
      <div class="hero-stats">
        <div class="stat">
          <strong>1</strong>
          <span>도구 완성</span>
        </div>
        <div class="stat-divider" />
        <div class="stat">
          <strong>무료</strong>
          <span>전부 다</span>
        </div>
        <div class="stat-divider" />
        <div class="stat">
          <strong>복붙</strong>
          <span>바로 가능</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 도구 목록 -->
  <section class="tools-section" id="tools">
    <div class="container">
      <div class="section-header">
        <h2>도구 모음</h2>
        <p>하나씩 추가하고 있어요. 요청 도구가 있으면 GitHub에 이슈 남겨주세요.</p>
      </div>

      <div class="tools-grid">
        {tools.map(tool => (
          <ToolCard {...tool} />
        ))}
      </div>
    </div>
  </section>

  <!-- 소개 섹션 -->
  <section class="about-section">
    <div class="container">
      <div class="about-card">
        <div class="about-icon">💡</div>
        <div class="about-content">
          <h3>이 사이트는 뭔가요?</h3>
          <p>
            바이브 코딩으로 뭔가 만들다 보면 자꾸 막히는 것들이 있어요.
            <em>파비콘은 어떻게 넣지? 플로팅 버튼은 어떻게 만들지?</em>
            검색하면 나오긴 하는데, 설명이 너무 길거나 코드가 제대로 동작 안 할 때가 많죠.
          </p>
          <p>
            여기서는 <strong>딱 필요한 것만</strong> 알려드려요.
            어떨 때 쓰는 건지, 코드는 어떻게 생겼는지, 바로 복사할 수 있는 코드.
            그것만요.
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* 히어로 */
.hero {
  padding: var(--space-24) 0 var(--space-16);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -50%;
  left: 50%;
  transform: translateX(-50%);
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(88,166,255,0.06) 0%, transparent 70%);
  pointer-events: none;
}

.hero-badge {
  margin-bottom: var(--space-4);
}

.hero h1 {
  margin-bottom: var(--space-6);
}

.accent { color: var(--accent); }

.hero-desc {
  font-size: 1.1rem;
  color: var(--text-secondary);
  max-width: 480px;
  margin: 0 auto var(--space-8);
  line-height: 1.8;
}

.hero-actions {
  display: flex;
  justify-content: center;
  gap: var(--space-3);
  flex-wrap: wrap;
  margin-bottom: var(--space-12);
}

.hero-stats {
  display: inline-flex;
  align-items: center;
  gap: var(--space-6);
  padding: var(--space-4) var(--space-8);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 100px;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}
.stat strong {
  font-size: 1.1rem;
  font-weight: 800;
  color: var(--accent);
}
.stat span {
  font-size: 0.75rem;
  color: var(--text-muted);
}

.stat-divider {
  width: 1px;
  height: 28px;
  background: var(--border);
}

/* 도구 목록 */
.tools-section {
  padding: var(--space-12) 0;
}

.section-header {
  margin-bottom: var(--space-8);
}
.section-header h2 { margin-bottom: var(--space-2); }
.section-header p { font-size: 0.9rem; }

.tools-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: var(--space-4);
}

/* 소개 */
.about-section {
  padding: var(--space-12) 0;
}

.about-card {
  display: flex;
  gap: var(--space-6);
  align-items: flex-start;
  padding: var(--space-8);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-xl);
  max-width: 720px;
}

.about-icon {
  font-size: 2rem;
  flex-shrink: 0;
}

.about-content h3 {
  margin-bottom: var(--space-4);
  font-size: 1.1rem;
}

.about-content p {
  font-size: 0.95rem;
  line-height: 1.8;
  color: var(--text-secondary);
  margin-bottom: var(--space-3);
}
.about-content p:last-child { margin-bottom: 0; }
.about-content em { color: var(--text-primary); font-style: normal; }
.about-content strong { color: var(--accent); }

@media (max-width: 640px) {
  .tools-grid { grid-template-columns: 1fr; }
  .hero-stats { flex-direction: column; gap: var(--space-2); }
  .stat-divider { width: 40px; height: 1px; }
  .about-card { flex-direction: column; }
}
</style>
