<script>
// SVG 파비콘 에디터 로직
(function() {
  const shapes = {
    lightning: `<path d="M18 4L8 18h8l-2 10 12-14h-8l2-10z" fill="ICON_COLOR"/>`,
    star: `<polygon points="16,3 19.5,12.5 30,13 22,20 24.5,30 16,24.5 7.5,30 10,20 2,13 12.5,12.5" fill="ICON_COLOR"/>`,
    heart: `<path d="M16 28s-13-8.3-13-16a7 7 0 0 1 13-3.6A7 7 0 0 1 29 12c0 7.7-13 16-13 16z" fill="ICON_COLOR"/>`,
    circle: `<circle cx="16" cy="16" r="9" fill="ICON_COLOR"/>`,
    letter: `<text x="16" y="22" font-family="Arial, sans-serif" font-size="18" font-weight="900" text-anchor="middle" fill="ICON_COLOR">V</text>`,
  };

  function generateSVG(bgColor, iconColor, shape) {
    return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
  <rect width="32" height="32" rx="6" fill="${bgColor}"/>
  ${shapes[shape].replace(/ICON_COLOR/g, iconColor)}
</svg>`;
  }

  function updatePreviews() {
    const bgColor = document.getElementById('bgColor').value;
    const iconColor = document.getElementById('iconColor').value;
    const shape = document.getElementById('iconShape').value;

    document.getElementById('bgColorVal').textContent = bgColor;
    document.getElementById('iconColorVal').textContent = iconColor;

    const svg = generateSVG(bgColor, iconColor, shape);
    const encoded = 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svg);

    [16, 32, 64, 128].forEach(size => {
      const el = document.getElementById(`preview-${size}`);
      if (el) {
        el.innerHTML = `<img src="${encoded}" width="${size}" height="${size}" style="display:block" />`;
      }
    });

    document.getElementById('svgOutput').textContent = svg;
  }

  // 이벤트 바인딩
  ['bgColor', 'iconColor', 'iconShape'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('input', updatePreviews);
  });

  // 복사 버튼
  const copyBtn = document.getElementById('copyEditorCode');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const code = document.getElementById('svgOutput').textContent;
      try {
        await navigator.clipboard.writeText(code);
        copyBtn.textContent = '✅ 복사됨!';
        setTimeout(() => { copyBtn.textContent = '코드 복사하기'; }, 2000);
      } catch (e) {
        console.error('복사 실패', e);
      }
    });
  }

  // 초기 렌더
  updatePreviews();
})();
</script>
