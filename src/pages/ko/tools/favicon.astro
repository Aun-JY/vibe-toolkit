---
// src/pages/ko/tools/favicon.astro
import ToolLayout from '../../../layouts/ToolLayout.astro';
import CodeBlock from '../../../components/CodeBlock.astro';

const basicFavicon = `<!-- 가장 기본적인 파비콘 (PNG) -->
<link rel="icon" href="/favicon.png" type="image/png">`;

const svgFavicon = `<!-- SVG 파비콘 (권장 방식) -->
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="icon" href="/favicon.png" type="image/png"><!-- 폴백용 -->`;

const fullFavicon = `<!-- ✅ 실전에서 쓰는 완전한 파비콘 세트 -->
<head>
  <!-- 기본 파비콘 -->
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">

  <!-- iOS/macOS Safari -->
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <!-- Android Chrome / PWA -->
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#0d1117">
</head>`;

const svgExample = `<!-- 직접 만드는 SVG 파비콘 예시 -->
<!-- /public/favicon.svg 파일로 저장하세요 -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
  <!-- 배경 원 -->
  <circle cx="16" cy="16" r="16" fill="#0d1117"/>

  <!-- 번개 아이콘 -->
  <path d="M18 4L8 18h8l-2 10 12-14h-8l2-10z"
        fill="#58a6ff"
        stroke="#58a6ff"
        stroke-width="0.5"/>
</svg>`;

const manifestJson = `// /public/manifest.json
{
  "name": "내 사이트 이름",
  "short_name": "내사이트",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "theme_color": "#0d1117",
  "background_color": "#0d1117",
  "display": "standalone"
}`;
---

<ToolLayout
  title="파비콘 (Favicon)"
  description="브라우저 탭, 북마크, 스마트폰 홈 화면에 표시되는 작은 아이콘. 웹사이트의 첫인상을 결정하는 중요한 요소예요."
  icon="🌐"
  category="HTML 기초"
  publishDate="2025-01-01"
  keywords={['파비콘', 'favicon', 'ico', 'svg', 'apple-touch-icon']}
  nextTool={{ title: '플로팅 버튼', href: '/ko/tools/floating-button/' }}
>

  <!-- 라이브 미리보기 -->
  <section class="preview-section">
    <div class="preview-label">
      <span class="tag">👁️ 라이브 미리보기</span>
    </div>
    <div class="preview-box">
      <!-- 브라우저 탭 시뮬레이터 -->
      <div class="browser-mock">
        <div class="browser-toolbar">
          <div class="browser-dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <div class="browser-address">
            <span>mysite.com</span>
          </div>
        </div>
        <div class="browser-tabs">
          <div class="tab active">
            <div class="tab-favicon">
              <svg width="14" height="14" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                <circle cx="16" cy="16" r="16" fill="#0d1117"/>
                <path d="M18 4L8 18h8l-2 10 12-14h-8l2-10z" fill="#58a6ff"/>
              </svg>
            </div>
            <span>바이브툴킷</span>
            <span class="tab-close">×</span>
          </div>
          <div class="tab">
            <div class="tab-favicon empty"></div>
            <span>파비콘 없는 사이트</span>
            <span class="tab-close">×</span>
          </div>
        </div>
        <div class="browser-content">
          <p>← 탭에 아이콘이 있는 사이트 vs 없는 사이트 비교</p>
        </div>
      </div>

      <!-- 북마크 시뮬레이터 -->
      <div class="bookmark-mock">
        <h4>북마크 바</h4>
        <div class="bookmarks">
          <div class="bookmark">
            <svg width="14" height="14" viewBox="0 0 32 32">
              <circle cx="16" cy="16" r="16" fill="#0d1117"/>
              <path d="M18 4L8 18h8l-2 10 12-14h-8l2-10z" fill="#58a6ff"/>
            </svg>
            <span>바이브툴킷</span>
          </div>
          <div class="bookmark no-icon">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="#8b949e">
              <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M5 8h6M8 5v6" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span>파비콘 없음</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- 파비콘이란? -->
  <h2>파비콘이 뭔가요?</h2>
  <p>
    <strong>Favicon</strong>은 <em>Favorite Icon</em>의 줄임말이에요.
    브라우저 탭, 북마크, 방문 기록, 스마트폰 홈 화면에서 보이는 작은 아이콘이에요.
  </p>
  <p>
    없어도 사이트가 동작하는 데 문제는 없지만, 없으면 탭에 🌐 또는 빈 아이콘이 표시돼서
    <strong>전문적이지 않아 보여요.</strong> 특히 여러 탭을 열어두고 사용하는 경우,
    파비콘이 있어야 "아 이게 내 사이트 탭이구나" 하고 구분할 수 있어요.
  </p>

  <!-- 간단한 역사 -->
  <div class="info-card">
    <div class="info-icon">📖</div>
    <div>
      <h4>잡다한 지식: 파비콘의 역사</h4>
      <p>
        파비콘은 <strong>1999년 Internet Explorer 5</strong>에서 처음 도입됐어요.
        당시에는 <code>favicon.ico</code>라는 파일을 사이트 루트에 두면 자동으로 인식했어요.
        지금도 많은 브라우저가 이 방식을 지원하는 이유예요.
        이후 W3C가 공식 표준화했고, 지금은 SVG, PNG, ICO 등 다양한 형식을 지원해요.
      </p>
    </div>
  </div>

  <!-- 형식 비교 -->
  <h2>어떤 형식을 써야 하나요?</h2>

  <div class="format-grid">
    <div class="format-card best">
      <div class="format-header">
        <span class="format-badge best">✅ 권장</span>
        <strong>SVG</strong>
      </div>
      <ul>
        <li>파일 크기 가장 작음</li>
        <li>어떤 크기에서도 선명함</li>
        <li>다크모드 대응 가능</li>
        <li>코드로 직접 편집 가능</li>
      </ul>
      <p class="format-note">단, IE 미지원 (요즘은 신경 안 써도 됨)</p>
    </div>

    <div class="format-card">
      <div class="format-header">
        <span class="format-badge ok">👍 무난</span>
        <strong>PNG</strong>
      </div>
      <ul>
        <li>모든 브라우저 지원</li>
        <li>투명 배경 가능</li>
        <li>32×32, 64×64 권장</li>
      </ul>
      <p class="format-note">SVG 폴백용으로 같이 쓰면 좋음</p>
    </div>

    <div class="format-card">
      <div class="format-header">
        <span class="format-badge legacy">🗿 레거시</span>
        <strong>ICO</strong>
      </div>
      <ul>
        <li>IE 포함 구형 브라우저 지원</li>
        <li>여러 크기를 하나의 파일에</li>
      </ul>
      <p class="format-note">IE 신경 안 써도 된다면 생략 가능</p>
    </div>
  </div>

  <!-- 코드 섹션 -->
  <h2>코드</h2>

  <h3>① 가장 기본 (PNG)</h3>
  <p>PNG 하나만 빠르게 추가하고 싶을 때:</p>
  <CodeBlock code={basicFavicon} lang="html" label="기본 PNG 파비콘" filename="index.html" />

  <h3>② SVG 파비콘 (권장)</h3>
  <p>SVG를 메인으로 쓰고, 구형 브라우저를 위해 PNG도 같이 선언해요:</p>
  <CodeBlock code={svgFavicon} lang="html" label="SVG + PNG 폴백" filename="index.html" />

  <h3>③ 실전 완전판</h3>
  <p>iOS 홈 화면 추가, PWA, 다크모드까지 대응하는 풀 세트예요:</p>
  <CodeBlock code={fullFavicon} lang="html" label="프로덕션 파비콘 세트" filename="index.html" />

  <h3>④ SVG 직접 만들기</h3>
  <p>
    디자인 툴 없이 코드로 직접 SVG 파비콘을 만들 수 있어요.
    <code>viewBox="0 0 32 32"</code>로 시작해서 원하는 모양을 그리면 돼요:
  </p>
  <CodeBlock code={svgExample} lang="html" label="SVG 파비콘 직접 만들기" filename="favicon.svg" />

  <h3>⑤ manifest.json (모바일 홈 화면용)</h3>
  <p>스마트폰 홈 화면에 추가할 때 쓰이는 PWA 설정 파일이에요:</p>
  <CodeBlock code={manifestJson} lang="json" label="PWA 매니페스트" filename="manifest.json" />

  <!-- SVG 파비콘 에디터 -->
  <h2>🎨 SVG 파비콘 즉석 에디터</h2>
  <p>아래에서 색상을 바꿔보고 마음에 들면 코드를 복사하세요:</p>

  <div class="favicon-editor">
    <div class="editor-controls">
      <div class="control-group">
        <label>배경색</label>
        <input type="color" id="bgColor" value="#0d1117" />
        <span id="bgColorVal" class="color-val">#0d1117</span>
      </div>
      <div class="control-group">
        <label>아이콘색</label>
        <input type="color" id="iconColor" value="#58a6ff" />
        <span id="iconColorVal" class="color-val">#58a6ff</span>
      </div>
      <div class="control-group">
        <label>모양</label>
        <select id="iconShape">
          <option value="lightning">번개</option>
          <option value="star">별</option>
          <option value="heart">하트</option>
          <option value="circle">동그라미</option>
          <option value="letter">문자 (V)</option>
        </select>
      </div>
    </div>

    <div class="editor-preview-area">
      <div class="preview-sizes">
        <div class="size-item">
          <div class="favicon-preview" id="preview-16" style="width:16px;height:16px;"></div>
          <span>16px</span>
        </div>
        <div class="size-item">
          <div class="favicon-preview" id="preview-32" style="width:32px;height:32px;"></div>
          <span>32px</span>
        </div>
        <div class="size-item">
          <div class="favicon-preview" id="preview-64" style="width:64px;height:64px;"></div>
          <span>64px</span>
        </div>
        <div class="size-item">
          <div class="favicon-preview" id="preview-128" style="width:128px;height:128px;"></div>
          <span>128px</span>
        </div>
      </div>

      <div class="editor-output">
        <pre id="svgOutput" class="svg-code"></pre>
        <button id="copyEditorCode" class="btn btn-primary" style="margin-top: 1rem;">
          코드 복사하기
        </button>
      </div>
    </div>
  </div>

  <!-- 자주 묻는 질문 -->
  <h2>자주 묻는 질문</h2>

  <div class="faq-list">
    <details class="faq-item">
      <summary>파비콘 파일은 어디에 두나요?</summary>
      <p>
        보통 <code>/public/</code> 폴더에 두고 <code>/favicon.svg</code>처럼 루트에서 접근하게 해요.
        Astro, Next.js, Vite 모두 <code>public</code> 폴더가 루트로 서빙돼요.
        그냥 HTML 사이트라면 <code>index.html</code>과 같은 폴더에 두면 돼요.
      </p>
    </details>
    <details class="faq-item">
      <summary>파비콘이 바뀌지 않아요!</summary>
      <p>
        브라우저 캐시 문제예요. <strong>강력 새로고침</strong>을 하면 돼요.
        Windows/Linux: <code>Ctrl + Shift + R</code>,
        Mac: <code>Cmd + Shift + R</code>.
        그래도 안 된다면 개발자 도구 → Network 탭 → "Disable cache" 체크 후 새로고침.
      </p>
    </details>
    <details class="faq-item">
      <summary>apple-touch-icon은 꼭 필요한가요?</summary>
      <p>
        iOS Safari에서 "홈 화면에 추가"를 하면 사용하는 아이콘이에요.
        없어도 되지만 있으면 훨씬 깔끔해 보여요.
        크기는 <strong>180×180px PNG</strong>를 권장해요.
      </p>
    </details>
    <details class="faq-item">
      <summary>SEO에 영향이 있나요?</summary>
      <p>
        파비콘 자체가 검색 순위에 직접 영향을 주진 않아요.
        하지만 Google 검색 결과 목록에 파비콘이 표시되고,
        클릭률(CTR)과 브랜드 인지도에 간접적으로 영향을 줄 수 있어요.
      </p>
    </details>
  </div>

  <!-- 체크리스트 -->
  <div class="checklist-card">
    <h3>✅ 파비콘 완료 체크리스트</h3>
    <ul>
      <li><label><input type="checkbox" /> <code>favicon.svg</code> 또는 <code>favicon.png</code> 파일 준비</label></li>
      <li><label><input type="checkbox" /> HTML <code>&lt;head&gt;</code>에 <code>&lt;link rel="icon"&gt;</code> 추가</label></li>
      <li><label><input type="checkbox" /> 브라우저 탭에서 확인</label></li>
      <li><label><input type="checkbox" /> (선택) <code>apple-touch-icon.png</code> 추가</label></li>
      <li><label><input type="checkbox" /> (선택) <code>manifest.json</code> 추가</label></li>
    </ul>
  </div>

</ToolLayout>

<style>
/* 라이브 미리보기 */
.preview-section {
  margin-bottom: var(--space-12);
}
.preview-label {
  margin-bottom: var(--space-4);
}
.preview-box {
  display: flex;
  gap: var(--space-6);
  flex-wrap: wrap;
}

/* 브라우저 목업 */
.browser-mock {
  flex: 1;
  min-width: 300px;
  background: #1e2530;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.browser-toolbar {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: 10px 14px;
  background: #161b22;
  border-bottom: 1px solid var(--border);
}

.browser-dots { display: flex; gap: 6px; }
.dot { width: 10px; height: 10px; border-radius: 50%; }
.dot.red    { background: #ff5f57; }
.dot.yellow { background: #febc2e; }
.dot.green  { background: #28c840; }

.browser-address {
  flex: 1;
  background: #0d1117;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 4px 10px;
  font-size: 0.75rem;
  color: var(--text-muted);
  font-family: var(--font-mono);
}

.browser-tabs {
  display: flex;
  border-bottom: 1px solid var(--border);
  background: #161b22;
}

.tab {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  font-size: 0.78rem;
  color: var(--text-muted);
  max-width: 180px;
  border-right: 1px solid var(--border);
}

.tab.active {
  background: #1e2530;
  color: var(--text-primary);
}

.tab-favicon {
  width: 14px;
  height: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tab-favicon.empty {
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: 2px;
}

.tab-close {
  margin-left: auto;
  color: var(--text-muted);
  font-size: 0.9rem;
}

.browser-content {
  padding: var(--space-6);
  font-size: 0.85rem;
  color: var(--text-muted);
}

/* 북마크 목업 */
.bookmark-mock {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-4) var(--space-6);
  min-width: 200px;
}

.bookmark-mock h4 {
  font-size: 0.75rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: var(--space-3);
}

.bookmarks {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.bookmark {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: 6px 10px;
  background: var(--bg-elevated);
  border-radius: var(--radius);
  font-size: 0.82rem;
  color: var(--text-secondary);
  border: 1px solid var(--border);
}

/* 형식 비교 */
.format-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: var(--space-4);
  margin: var(--space-6) 0;
}

.format-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-5);
}

.format-card.best {
  border-color: rgba(63,185,80,0.3);
  background: rgba(63,185,80,0.04);
}

.format-header {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}

.format-header strong {
  font-family: var(--font-mono);
  font-size: 1rem;
  color: var(--text-primary);
}

.format-badge {
  font-size: 0.72rem;
  font-weight: 700;
  padding: 0.15em 0.5em;
  border-radius: 4px;
}
.format-badge.best   { background: rgba(63,185,80,0.15); color: var(--green); }
.format-badge.ok     { background: rgba(88,166,255,0.15); color: var(--accent); }
.format-badge.legacy { background: rgba(139,148,158,0.15); color: var(--text-secondary); }

.format-card ul {
  list-style: none;
  padding: 0;
  margin: 0 0 var(--space-3);
}
.format-card li {
  font-size: 0.85rem;
  color: var(--text-secondary);
  padding: 2px 0;
}
.format-card li::before { content: '• '; color: var(--text-muted); }

.format-note {
  font-size: 0.78rem !important;
  color: var(--text-muted) !important;
  margin: 0 !important;
}

/* 정보 카드 */
.info-card {
  display: flex;
  gap: var(--space-4);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-left: 3px solid var(--accent);
  border-radius: var(--radius);
  padding: var(--space-5);
  margin: var(--space-6) 0;
}
.info-icon { font-size: 1.5rem; flex-shrink: 0; }
.info-card h4 { margin-bottom: var(--space-2); font-size: 0.95rem; }
.info-card p { margin: 0; font-size: 0.9rem; }

/* FAQ */
.faq-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin: var(--space-6) 0;
}

.faq-item {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}

.faq-item summary {
