---
// src/components/Footer.astro
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">

    <div class="footer-left">
      <span class="footer-logo">⚡ 바이브툴킷</span>
      <p class="footer-desc">바이브 코딩 초보자를 위한 실용적인 웹 도구 모음집</p>
    </div>

    <div class="footer-links">
      <div class="footer-col">
        <h4>페이지</h4>
        <a href="/ko/">홈</a>
        <a href="/ko/tools/">도구 모음</a>
        <a href="/ko/privacy/">개인정보처리방침</a>
      </div>
      <div class="footer-col">
        <h4>도구</h4>
        <a href="/ko/tools/favicon/">파비콘</a>
        <a href="/ko/tools/floating-icon/">플로팅 아이콘</a>
        <!-- 추가할수록 여기에 계속 추가 -->
      </div>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container">
      <span>© {year} 바이브툴킷. 모든 코드는 자유롭게 사용하세요.</span>
    </div>
  </div>
</footer>

<style>
.site-footer {
  margin-top: var(--space-24);
  border-top: 1px solid var(--border-light);
  background: var(--bg-card);
}

.footer-inner {
  display: flex;
  gap: var(--space-16);
  padding: var(--space-12) var(--space-6);
  flex-wrap: wrap;
}

.footer-left {
  flex: 1;
  min-width: 200px;
}

.footer-logo {
  font-weight: 800;
  font-size: 1rem;
  color: var(--text-primary);
}

.footer-desc {
  margin-top: var(--space-2);
  font-size: 0.85rem;
  color: var(--text-muted);
  max-width: 260px;
  line-height: 1.6;
}

.footer-links {
  display: flex;
  gap: var(--space-12);
  flex-wrap: wrap;
}

.footer-col {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  min-width: 120px;
}

.footer-col h4 {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: var(--space-1);
}

.footer-col a {
  font-size: 0.875rem;
  color: var(--text-secondary);
}
.footer-col a:hover { color: var(--text-primary); }

.footer-bottom {
  border-top: 1px solid var(--border-light);
  padding: var(--space-4) var(--space-6);
  font-size: 0.8rem;
  color: var(--text-muted);
}

@media (max-width: 640px) {
  .footer-inner { gap: var(--space-8); }
}
</style>
